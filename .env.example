# EmailJS — used by the contact form to send messages straight to your inbox
# with no backend required. Get these from https://dashboard.emailjs.com
# (Account > General for the public key, Email Services for service ID,
# Email Templates for template ID)

REACT_APP_EMAILJS_SERVICE_ID=
REACT_APP_EMAILJS_TEMPLATE_ID=
REACT_APP_EMAILJS_PUBLIC_KEY=
